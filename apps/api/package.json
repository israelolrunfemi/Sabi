{
  "name": "sabi-api",
  "version": "1.0.0",
  "description": "Sabi — Intelligent Informal Economy Platform API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "seed:profiles": "ts-node-dev --transpile-only --exit-child src/seeds/profiles.seed.ts",
    "seed:profiles:dist": "node dist/seeds/profiles.seed.js",
    "seed:profiles:prod": "npm run build && node dist/seeds/profiles.seed.js",
    "build": "tsc",
    "db:migrate": "ts-node-dev --transpile-only --exit-child src/scripts/db-migrate.ts",
    "test": "tsc && node --test \"dist/**/*.test.js\"",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@google/genai": "^2.0.1",
    "@ngrok/ngrok": "^1.7.0",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "uuid": "^14.0.0",
    "winston": "^3.13.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/pdfkit": "^0.17.6",
    "@types/uuid": "^11.0.0",
    "pdfkit": "^0.18.0",
    "sequelize-cli": "^6.6.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
